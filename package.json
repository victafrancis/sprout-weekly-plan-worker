{
  "name": "sprout-weekly-plan-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node22 --format=cjs --loader:.md=text --outfile=dist/handler.cjs",
    "package": "npm run build && node -e \"const fs=require('node:fs');fs.copyFileSync('dist/handler.cjs','dist/handler.js');\" && cd dist && bestzip lambda.zip handler.js",
    "invoke:local": "node -e \"const m=require('./dist/handler.cjs');Promise.resolve(m.handler({requestSource:'manual',requestedAt:new Date().toISOString()})).then(r=>{console.log(JSON.stringify(r,null,2));}).catch(e=>{console.error(e);process.exit(1);});\"",
    "deploy:cli": "scripts\\deploy-lambda.cmd",
    "run:local": "tsx src/local-runner.ts",
    "test": "tsx --test tests/worker-dynamodb.test.ts tests/prompt-fallback.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.883.0",
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/lib-dynamodb": "^3.883.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.13.10",
    "bestzip": "^2.2.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
